{
  "name": "Size Suggester",
  "version": "1.0",
  "manifest_version": 3,
  "description": "Automatically suggests your clothing size based on your measurements.",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "options_page": "onboarding.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Size Suggester",
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["sizing.js", "content.js"],
      "css": ["injected.css"],
      "run_at": "document_idle"
    }
  ]
}
